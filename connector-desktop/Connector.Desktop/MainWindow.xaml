<Window x:Class="Connector.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Structura Connector"
        Height="700"
        Width="1024"
        MinHeight="620"
        MinWidth="920"
        Background="#0A1018"
        Loaded="Window_Loaded">
    <Window.Resources>
        <LinearGradientBrush x:Key="WindowBackground" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#08111D" Offset="0" />
            <GradientStop Color="#102236" Offset="0.55" />
            <GradientStop Color="#081018" Offset="1" />
        </LinearGradientBrush>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EEF6FF" />
            <Setter Property="FontFamily" Value="Bahnschrift" />
        </Style>

        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#A9BBD3" />
            <Setter Property="FontFamily" Value="Bahnschrift" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="#F3F8FF" />
            <Setter Property="Background" Value="#111C2C" />
            <Setter Property="BorderBrush" Value="#2D4466" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="FontFamily" Value="Bahnschrift" />
            <Setter Property="Height" Value="36" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Foreground" Value="#F3F8FF" />
            <Setter Property="Background" Value="#111C2C" />
            <Setter Property="BorderBrush" Value="#2D4466" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="FontFamily" Value="Bahnschrift" />
            <Setter Property="Height" Value="36" />
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="BorderBrush" Value="#2A3E5C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#0F1928" />
            <Setter Property="Margin" Value="0,0,12,12" />
        </Style>

        <Style x:Key="BaseButton" TargetType="Button">
            <Setter Property="Foreground" Value="#F3FCFF" />
            <Setter Property="Background" Value="#16324D" />
            <Setter Property="BorderBrush" Value="#2F5E8A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="13,9" />
            <Setter Property="Height" Value="38" />
            <Setter Property="FontFamily" Value="Bahnschrift" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="8,0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="root" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="root" Property="Opacity" Value="0.8" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="root" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#10607A" />
            <Setter Property="BorderBrush" Value="#2AA1C4" />
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#1A2A40" />
            <Setter Property="BorderBrush" Value="#34557A" />
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#4A1F2A" />
            <Setter Property="BorderBrush" Value="#8A4052" />
        </Style>
    </Window.Resources>

    <Grid>
        <Border Background="{StaticResource WindowBackground}" />

        <Canvas IsHitTestVisible="False" Opacity="0.28">
            <Ellipse Width="360" Height="360" Fill="#1A84C6" Canvas.Top="-150" Canvas.Left="-100" />
            <Ellipse Width="280" Height="280" Fill="#1C4D8E" Canvas.Top="520" Canvas.Left="760" />
        </Canvas>

        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    CornerRadius="16"
                    BorderBrush="#2A4466"
                    BorderThickness="1"
                    Background="#102033"
                    Padding="16"
                    Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="56" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="44"
                            Height="44"
                            CornerRadius="22"
                            Background="#0E6078"
                            BorderBrush="#43B2CF"
                            BorderThickness="1"
                            VerticalAlignment="Top">
                        <TextBlock Text="S"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Structura Connector" FontSize="30" FontWeight="SemiBold" />
                        <TextBlock Text="Введите токен и приложение само выполнит подключение и фоновую работу"
                                   Margin="0,6,0,0"
                                   Foreground="#A9BBD3" />
                    </StackPanel>
                </Grid>
            </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="0.9*" />
                    </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Быстрое подключение" FontSize="19" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="1" Text="Укажите только токен устройства, остальные параметры зашиты в приложение."
                                   Margin="0,6,0,12" Foreground="#A9BBD3" TextWrapping="Wrap" />

                        <Grid Grid.Row="2" Margin="0,0,0,8" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="URL сервера" VerticalAlignment="Center" />
                            <TextBox x:Name="ServerUrlTextBox" Grid.Column="1" />
                        </Grid>

                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                             <Label Grid.Row="0" Grid.Column="0" Content="Токен устройства" VerticalAlignment="Center" />
                             <PasswordBox x:Name="TokenPasswordBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,10" />

                            <Button x:Name="ConnectByTokenButton"
                                    Grid.Row="1"
                                     Grid.Column="1"
                                     Style="{StaticResource PrimaryButton}"
                                     Content="Подключиться по токену"
                                     Click="ConnectByToken_Click"
                                     Margin="0,0,0,12"
                                     Height="42" />

                             <Separator Grid.Row="2" Grid.ColumnSpan="2" Margin="0,0,0,12" Background="#2A3E5C" Visibility="Collapsed" />

                             <TextBlock Grid.Row="3" Grid.ColumnSpan="2" Text="Параметры устройства" FontSize="17" FontWeight="SemiBold" Margin="0,0,0,10" Visibility="Collapsed" />

                             <Label Grid.Row="4" Grid.Column="0" Content="ID устройства" VerticalAlignment="Center" Visibility="Collapsed" />
                             <TextBox x:Name="DeviceIdTextBox" Grid.Row="4" Grid.Column="1" Margin="0,0,0,10" Visibility="Collapsed" />

                             <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Visibility="Collapsed">
                                 <StackPanel Width="180" Margin="0,0,12,0">
                                     <Label Content="Интервал heartbeat (сек)" />
                                     <TextBox x:Name="IntervalTextBox" />
                                </StackPanel>
                                <StackPanel>
                                    <Label Content="Состояние heartbeat" />
                                    <TextBlock x:Name="RunStateTextBlock" Text="Автоотправка heartbeat: выключена" Foreground="#F9C56D" Margin="0,9,0,0" />
                                </StackPanel>
                            </StackPanel>

                             <CheckBox x:Name="AutoStartCheckBox"
                                       Grid.Row="6"
                                       Grid.ColumnSpan="2"
                                       Margin="0,10,0,8"
                                       Foreground="#D7E6FA"
                                       FontFamily="Bahnschrift"
                                       Content="Запускать Structura Connector при входе в Windows"
                                       Visibility="Collapsed" />

                             <WrapPanel Grid.Row="7" Grid.ColumnSpan="2" Margin="0,4,0,0" Visibility="Collapsed">
                                 <Button x:Name="SaveButton" Style="{StaticResource SecondaryButton}" Content="Сохранить настройки" Click="Save_Click" />
                                 <Button x:Name="TestConnectionButton" Style="{StaticResource SecondaryButton}" Content="Проверить сервер" Click="TestConnection_Click" />
                                 <Button x:Name="SendNowButton" Style="{StaticResource SecondaryButton}" Content="Отправить heartbeat" Click="SendNow_Click" />
                                <Button x:Name="StartButton" Style="{StaticResource PrimaryButton}" Content="Включить автоотправку" Click="Start_Click" />
                                <Button x:Name="StopButton" Style="{StaticResource DangerButton}" Content="Выключить" Click="Stop_Click" />
                            </WrapPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Обновления приложения" FontSize="19" FontWeight="SemiBold" />
                        <TextBlock Text="Проверка и установка новой версии Structura Connector."
                                   Margin="0,6,0,12" Foreground="#A9BBD3" TextWrapping="Wrap" />

                        <Label Content="Логин SMB" Visibility="Collapsed" />
                        <TextBox x:Name="SmbLoginTextBox" Margin="0,0,0,10" Visibility="Collapsed" />

                        <Label Content="Пароль SMB" Visibility="Collapsed" />
                        <PasswordBox x:Name="SmbPasswordBox" Margin="0,0,0,10" Visibility="Collapsed" />

                        <Label Content="Путь папки" Visibility="Collapsed" />
                        <TextBox x:Name="SmbSharePathTextBox" Margin="0,0,0,12" Visibility="Collapsed" />

                        <WrapPanel Visibility="Collapsed">
                            <Button x:Name="ConnectSmbButton" Style="{StaticResource PrimaryButton}" Content="Войти в SMB-папку" Click="ConnectSmb_Click" />
                            <Button x:Name="OpenSmbFolderButton" Style="{StaticResource SecondaryButton}" Content="Открыть BIM_Models" Click="OpenSmbFolder_Click" />
                        </WrapPanel>

                        <Separator Margin="0,8,0,10" Background="#2A3E5C" />

                        <TextBlock Text="Обновления" FontSize="17" FontWeight="SemiBold" />
                        <Label Content="URL manifest" Visibility="Collapsed" />
                        <TextBox x:Name="UpdateManifestUrlTextBox" Margin="0,0,0,8" Visibility="Collapsed" />
                        <TextBlock x:Name="UpdateStateTextBlock" Text="Обновление: не проверялось" Foreground="#A9BBD3" Margin="0,0,0,12" TextWrapping="Wrap" />

                        <WrapPanel>
                            <Button x:Name="UpdateActionButton" Style="{StaticResource SecondaryButton}" Content="Проверить обновление" Click="UpdateAction_Click" />
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2"
                    CornerRadius="16"
                    BorderBrush="#2A3E5C"
                    BorderThickness="1"
                    Background="#0F1928"
                    Padding="14"
                    Margin="0,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Журнал (последние события)" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBox x:Name="LogTextBox"
                             Grid.Row="1"
                             IsReadOnly="True"
                             Height="110"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled"
                             FontFamily="Consolas"
                             FontSize="13"
                             Background="#0B1320"
                             BorderBrush="#2A3E5C"
                             Foreground="#EDF5FF" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
